# VolunteerSync Production Environment Variables
# Copy this file to .env and fill in with your actual values
# NEVER commit .env to version control

# ===========================================
# Database Configuration (PostgreSQL 16)
# ===========================================
DB_NAME=volunteersync
DB_USER=volunteersync
DB_PASSWORD=CHANGE_ME_secure_postgres_password_min_16_chars
DB_PORT=5432
DB_SSLMODE=require
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300s

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_secure_redis_password
REDIS_DB=0

# ===========================================
# JWT Authentication
# ===========================================
# CRITICAL: Must be at least 32 characters for security
JWT_SECRET=CHANGE_ME_minimum_32_character_random_string_for_jwt_signing
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===========================================
# API URLs (Frontend)
# ===========================================
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ===========================================
# Feature Flags
# ===========================================
NEXT_PUBLIC_ENABLE_PWA=false
NEXT_PUBLIC_ENABLE_MAPS=true
NEXT_PUBLIC_ENABLE_CHARTS=true

# ===========================================
# Security
# ===========================================
ENABLE_HTTPS=true
ENABLE_SECURITY_HEADERS=true

# ===========================================
# Service Ports (Optional - defaults shown)
# ===========================================
BACKEND_PORT=8080
FRONTEND_PORT=3000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ===========================================
# Optional: Analytics
# ===========================================
NEXT_PUBLIC_ANALYTICS_ID=

# ===========================================
# Optional: Email (Future)
# ===========================================
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# ===========================================
# Optional: Cloud Storage (Future)
# ===========================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=
