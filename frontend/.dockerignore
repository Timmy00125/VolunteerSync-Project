# Frontend .dockerignore
# Exclude unnecessary files from Docker build context

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# Build artifacts
.next/
out/
dist/
build/

# Testing
coverage/
.nyc_output/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
tests/
__tests__/
test/
**/*.test.*
**/*.spec.*

# Git
.git
.gitignore
.gitattributes

# IDE
.vscode
.idea
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# Environment and config
.env
.env.*
.env.local
.env.development
.env.test
.env.production
.env*.local

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
README.md
*.md
docs/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# ESLint and Prettier
.eslintcache
.prettierignore

# Playwright
playwright-report/
test-results/

# Miscellaneous
.turbo/
.cache/
tmp/
temp/
*.tmp
